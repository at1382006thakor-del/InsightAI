# Database Connections (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./insightai.db
# Example Postgres connection string for Neon:
# DATABASE_URL=postgresql://user:password@neon-host:5432/insightai?sslmode=require

# JWT Tokens configuration
SECRET_KEY=generate-a-cryptographically-secure-random-key-phrase
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini completion key
GEMINI_API_KEY=your-gemini-api-key-here

# API server port
PORT=8000
